<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext (plain HTTP) traffic to any host.
  Required for connecting to a local ezpm2gui server over http:// on Android 9+.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
